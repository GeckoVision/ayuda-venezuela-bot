# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).

# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# LLM provider: openrouter (free, default) | anthropic
SOSBOT_PROVIDER=openrouter

# If SOSBOT_PROVIDER=openrouter
OPENROUTER_API_KEY=

# If SOSBOT_PROVIDER=anthropic  (more reliable tool-calling, ~$0.005/chat — use for judging)
ANTHROPIC_API_KEY=

# Optional
# SOSBOT_MODEL=            # override the default model id
# SOSBOT_MODE=live         # "live" (real API) or "recorded" ($0 offline, synthesized)
